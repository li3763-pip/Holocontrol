# Normalizar todos los archivos de texto a LF en el repositorio
* text=auto eol=lf

# Archivos de texto explícitos → siempre LF
*.js      text eol=lf
*.html    text eol=lf
*.css     text eol=lf
*.json    text eol=lf
*.jsonc   text eol=lf
*.md      text eol=lf
*.sql     text eol=lf
*.kt      text eol=lf
*.xml     text eol=lf
*.toml    text eol=lf
*.properties text eol=lf
*.gradle  text eol=lf
*.kts     text eol=lf

# Gradlew (script de shell) → LF obligatorio para que funcione en Linux/Mac
gradlew   text eol=lf

# Binarios → sin conversión
*.png     binary
*.jpg     binary
*.jpeg    binary
*.ico     binary
*.apk     binary
*.jar     binary
*.zip     binary
*.keystore binary

